### Autostart Applications
# Environment variable
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

# Dunst
exec dunst

# Blueman-applet
exec blueman-applet

# Polkit authentication
exec /usr/lib/polkit-kde-authentication-agent-1
# exec /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 &
    
# Cliphist
exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store

# Set wallpaper
exec swaybg -i /home/kevin/.local/share/wallpapers/summer/wallhaven-7p7qeo.jpg -m fill

# Idle configuration
# This will lock your creen after 300 seconds of inactivity, then turn off
# your displays after another 300 seconds, and turn your screens back on when
# resumed. It will also lock your screen before your computer goes to sleep.
exec swayidle -w \
        timeout 600 'swaylock -f -C ~/.config/sway/swaylock/config' \
        timeout 1200 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
        before-sleep 'swaylock -f -C ~/.config/sway/swaylock/config'
